// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// 示例数据模型 - 用户表
model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}

// 示例数据模型 - 文章表
model Post {
    id        String   @id @default(cuid())
    title     String
    content   String?
    published Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("posts")
}

// 向量存储表 - 用于存储文本嵌入向量
model Embedding {
    id        String                      @id @default(cuid())
    content   String // 原始文本内容
    embedding Unsupported("vector(1536)") // OpenAI 嵌入向量维度为 1536
    metadata  Json? // 可选的元数据
    createdAt DateTime                    @default(now())

    @@map("embeddings")
}

// 候选人简历分析结果表
model CandidateProfile {
    id              String                      @id @default(cuid())
    candidateId     String                      @map("candidate_id")
    name            String
    aiReport        Json                        @map("ai_report") // AI 分析报告
    resumeEmbedding Unsupported("vector(1536)") @map("resume_embedding") // 简历向量
    pdfUrl          String                      @map("pdf_url") // PDF 文件地址
    createdAt       DateTime                    @default(now()) @map("created_at")
    updatedAt       DateTime                    @updatedAt @map("updated_at")

    @@map("candidate_profiles")
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// 示例数据模型 - 用户表
model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}

// 示例数据模型 - 文章表
model Post {
    id        String   @id @default(cuid())
    title     String
    content   String?
    published Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("posts")
}

// 向量存储表 - 用于存储文本嵌入向量
model Embedding {
    id        String                      @id @default(cuid())
    content   String // 原始文本内容
    embedding Unsupported("vector(2048)") // 当前嵌入模型维度为 2048
    metadata  Json? // 可选的元数据
    createdAt DateTime                    @default(now())

    @@map("embeddings")
}

// 候选人简历分析结果表
model CandidateProfile {
    id              String                      @id @default(cuid())
    candidateId     String                      @map("candidate_id")
    name            String
    aiReport        Json                        @map("ai_report") // AI 分析报告
    resumeEmbedding Unsupported("vector(2048)") @map("resume_embedding") // 简历向量
    pdfUrl          String                      @map("pdf_url") // PDF 文件地址
    createdAt       DateTime                    @default(now()) @map("created_at")
    updatedAt       DateTime                    @updatedAt @map("updated_at")
    interviewTask   InterviewTask?

    @@map("candidate_profiles")
}

model InterviewTask {
    id                 String           @id @default(cuid())
    candidateProfileId String           @unique @map("candidate_profile_id")
    candidateId        String           @map("candidate_id")
    questions          Json
    answers            Json?
    status             String           @default("PENDING")
    evaluation         Json?
    evaluatedAt        DateTime?        @map("evaluated_at")
    createdAt          DateTime         @default(now()) @map("created_at")
    updatedAt          DateTime         @updatedAt @map("updated_at")
    candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

    @@index([candidateId])
    @@map("interview_tasks")
}
